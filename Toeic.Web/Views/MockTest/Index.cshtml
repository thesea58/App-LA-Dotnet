@model IReadOnlyList<Toeic.Domain.Entities.MockTest>
@{
    ViewData["Title"] = "Mock Test";
}

<h1>Mock Test</h1>

@if (!Model.Any())
{
    <p>No mock tests available.</p>
}
else
{
    @foreach (var test in Model)
    {
        <div class="feature-card mb-3">
            <h3>@test.Title</h3>
            <p>@test.Description</p>
            <p><strong>Duration:</strong> @test.DurationMinutes minutes</p>
            <form asp-action="Start" method="post">
                <input type="hidden" name="mockTestId" value="@test.Id" />
                <button type="submit" class="btn btn-primary">Start</button>
            </form>
        </div>
    }
}
