@model Toeic.Web.Models.Teacher.ClassDetailsViewModel
@{
    ViewData["Title"] = "Class Details";
}

<h1>@Model.ClassRoom.Name</h1>
<p>@Model.ClassRoom.Description</p>
<p><strong>Created:</strong> @Model.ClassRoom.CreatedAt.ToLocalTime()</p>

@if (TempData["TeacherError"] is string error)
{
    <div class="alert alert-danger">@error</div>
}
@if (TempData["TeacherSuccess"] is string success)
{
    <div class="alert alert-success">@success</div>
}

<h3>Add Student by Email</h3>
<form asp-action="EnrollStudent" asp-route-id="@Model.ClassRoom.Id" method="post" class="row g-2 mb-4">
    <div class="col-md-6">
        <input name="studentEmail" class="form-control" placeholder="student@email.com" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Add Student</button>
    </div>
</form>

<h3>Enrolled Students</h3>
@if (!Model.Students.Any())
{
    <p>No students enrolled yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Email</th>
                <th>Enrolled At</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var student in Model.Students)
        {
            <tr>
                <td>@student.Email</td>
                <td>@student.EnrolledAt.ToLocalTime()</td>
            </tr>
        }
        </tbody>
    </table>
}

<a asp-action="Index" class="btn btn-secondary">Back to classes</a>
