@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="hero-content">
        <h1>TOEIC Learning App 2026</h1>
        <p>
            A simple web application for practicing TOEIC Listening and Reading.
            This app will help learners study vocabulary, grammar, practice questions,
            and mock tests step by step.
        </p>

        <div class="hero-actions">
            <a class="btn btn-primary" asp-controller="Dashboard" asp-action="Index">Go to Dashboard</a>
            <a class="btn btn-outline-secondary" asp-controller="Practice" asp-action="Index">Start Practice</a>
        </div>
    </div>
</section>