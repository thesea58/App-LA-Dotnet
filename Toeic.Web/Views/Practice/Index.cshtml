@{
    ViewData["Title"] = "Practice";
}

<h1>Practice</h1>

<p>Select a TOEIC part to begin practice.</p>
<p><a class="btn btn-outline-secondary btn-sm" asp-action="Result">View My Practice Result</a></p>

<div class="card-grid">
    @for (var i = 1; i <= 7; i++)
    {
        <a class="feature-card text-decoration-none text-dark" asp-action="Part" asp-route-partNumber="@i">
            <strong>Part @i</strong>
            <div>Open practice set</div>
        </a>
    }
</div>
