@model Toeic.Web.Models.Practice.PracticeQuestionViewModel
@{
    ViewData["Title"] = "Practice Question";
}

<h1>Practice Question</h1>

<form asp-action="Submit" method="post" class="col-lg-8">
    <input type="hidden" name="questionId" value="@Model.Question.Id" />

    <div class="card p-3 mb-3">
        <p><strong>@Model.Question.QuestionText</strong></p>

        @foreach (var option in Model.Question.AnswerOptions.OrderBy(o => o.Label))
        {
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="selectedAnswerOptionId" id="option_@option.Id" value="@option.Id" required />
                <label class="form-check-label" for="option_@option.Id">
                    @option.Label. @option.Text
                </label>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Submit</button>
    <a class="btn btn-secondary" asp-action="Part" asp-route-partNumber="@((int)Model.Question.Part)">Back to Part</a>
</form>
