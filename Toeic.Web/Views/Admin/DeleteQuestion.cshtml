@model Toeic.Domain.Entities.Question
@{
    ViewData["Title"] = "Delete Question";
}

<h1>Delete Question</h1>

<p>Are you sure you want to delete this question?</p>

<div class="card p-3 mb-3">
    <strong>@Model.QuestionText</strong>
    <div>Part: @Model.Part | Skill: @Model.Skill</div>
</div>

<form asp-action="DeleteQuestionConfirmed" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Questions" class="btn btn-secondary">Cancel</a>
</form>
