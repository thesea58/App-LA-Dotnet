@model IReadOnlyList<Toeic.Domain.Entities.Question>
@{
    ViewData["Title"] = "Manage Questions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Question Management</h1>
    <a class="btn btn-primary" asp-action="CreateQuestion">Create Question</a>
</div>

@if (!Model.Any())
{
    <p>No question records found.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Part</th>
                    <th>Skill</th>
                    <th>QuestionText</th>
                    <th>Difficulty</th>
                    <th>Topic</th>
                    <th>GrammarTag</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Part</td>
                    <td>@item.Skill</td>
                    <td>@item.QuestionText</td>
                    <td>@item.Difficulty</td>
                    <td>@item.Topic</td>
                    <td>@item.GrammarTag</td>
                    <td>
                        <a asp-action="QuestionDetails" asp-route-id="@item.Id">Details</a> |
                        <a asp-action="EditQuestion" asp-route-id="@item.Id">Edit</a> |
                        <a asp-action="DeleteQuestion" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
