@model Toeic.Web.Models.Admin.QuestionFormViewModel

<div class="mb-3">
    <label asp-for="QuestionText" class="form-label"></label>
    <textarea asp-for="QuestionText" class="form-control" rows="3"></textarea>
    <span asp-validation-for="QuestionText" class="text-danger"></span>
</div>

<div class="row g-3">
    <div class="col-md-3">
        <label asp-for="Part" class="form-label"></label>
        <select asp-for="Part" class="form-select" asp-items="Html.GetEnumSelectList<Toeic.Domain.Enums.ToeicPart>()">
            <option value="">-- Select --</option>
        </select>
        <span asp-validation-for="Part" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Skill" class="form-label"></label>
        <select asp-for="Skill" class="form-select" asp-items="Html.GetEnumSelectList<Toeic.Domain.Enums.ToeicSkill>()">
            <option value="">-- Select --</option>
        </select>
        <span asp-validation-for="Skill" class="text-danger"></span>
    </div>

    <div class="col-md-2">
        <label asp-for="Difficulty" class="form-label"></label>
        <input asp-for="Difficulty" class="form-control" min="1" max="5" />
    </div>

    <div class="col-md-4">
        <label asp-for="Topic" class="form-label"></label>
        <input asp-for="Topic" class="form-control" />
    </div>
</div>

<div class="mb-3 mt-3">
    <label asp-for="GrammarTag" class="form-label"></label>
    <input asp-for="GrammarTag" class="form-control" />
</div>

<div class="mb-3">
    <label asp-for="Explanation" class="form-label"></label>
    <textarea asp-for="Explanation" class="form-control" rows="3"></textarea>
</div>
