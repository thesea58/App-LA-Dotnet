@model Toeic.Web.Models.Admin.QuestionImportViewModel
@{
    ViewData["Title"] = "Question Import";
}

<h1>Import Questions from JSON</h1>

@if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
{
    <div class="alert alert-success">@Model.ResultMessage</div>
}

<form asp-action="QuestionImport" method="post" class="col-lg-10">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="JsonPayload" class="form-label"></label>
        <textarea asp-for="JsonPayload" class="form-control" rows="16" placeholder='[{"QuestionText":"...","Part":"Part5","Skill":"Reading","Options":[...]}]'></textarea>
        <span asp-validation-for="JsonPayload" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Import</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
