@model Toeic.Web.Models.Dashboard.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<div class="card-grid">
    <div class="feature-card">
        <h3>Total Practice</h3>
        <p>@Model.TotalPracticeQuestions questions</p>
    </div>
    <div class="feature-card">
        <h3>Overall Accuracy</h3>
        <p>@Model.OverallAccuracy%</p>
    </div>
    <div class="feature-card">
        <h3>Mock Tests Completed</h3>
        <p>@Model.MockTestsCompleted</p>
    </div>
    <div class="feature-card">
        <h3>Latest Mock Test Score</h3>
        <p>@(Model.LatestMockTestScore?.ToString() ?? "N/A")</p>
    </div>
    <div class="feature-card">
        <h3>Weakest GrammarTag</h3>
        <p>@Model.WeakestGrammarTag</p>
    </div>
</div>

<h3 class="mt-4">Recommended Next Study</h3>
<div class="feature-card">
@if (!Model.Recommendations.Any())
{
    <p>No recommendation yet. Keep practicing.</p>
}
else
{
    <ul class="mb-0">
    @foreach (var item in Model.Recommendations)
    {
        <li>@item</li>
    }
    </ul>
}
</div>

<h3 class="mt-4">Accuracy by Part</h3>
@if (!Model.PartStats.Any())
{
    <p>No part statistics yet.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Part</th>
                <th>Accuracy</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.PartStats)
        {
            <tr>
                <td>@item.Part</td>
                <td>@item.Accuracy%</td>
            </tr>
        }
        </tbody>
    </table>
}

<h3 class="mt-4">My Assignments</h3>
@if (!Model.StudentAssignments.Any())
{
    <p>No assignments from your classes yet.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Class</th>
                <th>Assignment</th>
                <th>Mock Test</th>
                <th>Due Date</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.StudentAssignments)
        {
            <tr>
                <td>@item.ClassName</td>
                <td>@item.Title</td>
                <td>@item.MockTestTitle</td>
                <td>@item.DueDate.ToLocalTime()</td>
            </tr>
        }
        </tbody>
    </table>
}
