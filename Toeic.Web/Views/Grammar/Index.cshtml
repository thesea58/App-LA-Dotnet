@model IReadOnlyList<Toeic.Web.Models.Grammar.GrammarClinicGroupViewModel>
@{
    ViewData["Title"] = "Grammar Clinic";
}

<h1>Grammar Clinic</h1>

@if (!Model.Any())
{
    <p>You have no incorrect practice attempts yet.</p>
}
else
{
    <div class="card-grid">
    @foreach (var item in Model)
    {
        <a class="feature-card text-decoration-none text-dark" asp-action="Tag" asp-route-tag="@item.GrammarTag">
            <h3>@item.GrammarTag</h3>
            <p>Wrong answers: @item.WrongCount</p>
        </a>
    }
    </div>
}
