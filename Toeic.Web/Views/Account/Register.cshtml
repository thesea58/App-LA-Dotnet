@model Toeic.Web.Models.Account.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    var returnUrl = (string?)ViewData["ReturnUrl"] ?? Url.Action("Index", "Dashboard");
}

<h1>Register</h1>

<form asp-action="Register" method="post" asp-route-returnUrl="@returnUrl" class="col-md-6">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" autocomplete="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create account</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
